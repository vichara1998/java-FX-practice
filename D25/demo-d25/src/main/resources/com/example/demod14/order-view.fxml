<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="470.0" prefWidth="649.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demod14.controller.OrderController">
   <children>
      <TableView fx:id="table" layoutX="65.0" layoutY="137.0" prefHeight="250.0" prefWidth="520.0">
        <columns>
          <TableColumn prefWidth="97.0" text="ID" />
          <TableColumn prefWidth="75.0" text="Brand" />
            <TableColumn prefWidth="84.0" text="Model" />
            <TableColumn prefWidth="67.0" text="Price" />
            <TableColumn prefWidth="95.0" text="Qnt" />
            <TableColumn prefWidth="101.0" text="Total" />
        </columns>
      </TableView>
      <Button layoutX="557.0" layoutY="57.0" mnemonicParsing="false" onAction="#addToCart" text="Add to Cart" />
      <Button layoutX="507.0" layoutY="410.0" mnemonicParsing="false" onAction="#order" text="Place Order" />
      <TextField fx:id="txtId" layoutX="54.0" layoutY="32.0" onAction="#searchById" promptText="ID" />
      <TextField fx:id="txtPrice" layoutX="54.0" layoutY="80.0" promptText="Price" />
      <TextField fx:id="txtModel" layoutX="218.0" layoutY="32.0" promptText="Model" />
      <TextField fx:id="txtBrand" layoutX="386.0" layoutY="32.0" promptText="Brand" />
      <TextField fx:id="txtQntOnHand" layoutX="218.0" layoutY="80.0" promptText="Qnt on Hand" />
      <TextField fx:id="txtQnt" layoutX="386.0" layoutY="80.0" promptText="Qnt" />
      <TextArea fx:id="lblTotal" layoutX="14.0" layoutY="404.0" prefHeight="25.0" prefWidth="178.0" text="Total :" />
      <TextField fx:id="txtOrderId" layoutX="272.0" layoutY="410.0" onAction="#searchById" promptText="Order ID" />
   </children>
</AnchorPane>
