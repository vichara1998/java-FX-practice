<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demod14.UpdateView">
   <children>
      <TextField fx:id="txtSearch" layoutX="67.0" layoutY="26.0" promptText="Search......." />
      <TextField fx:id="txtQt" layoutX="67.0" layoutY="253.0" promptText="Quantity" />
      <TextField fx:id="txtPrice" layoutX="67.0" layoutY="212.0" promptText="Price" />
      <TextField fx:id="txtModel" layoutX="67.0" layoutY="161.0" promptText="Model" />
      <TextField fx:id="txtBrand" layoutX="67.0" layoutY="114.0" promptText="Brand" />
      <Button layoutX="260.0" layoutY="26.0" mnemonicParsing="false" onAction="#search" text="Search" />
      <Button layoutX="164.0" layoutY="325.0" mnemonicParsing="false" onAction="#cancle" text="Cancel" />
      <Button layoutX="41.0" layoutY="325.0" mnemonicParsing="false" onAction="#update" text="Update" />
   </children>
</AnchorPane>
