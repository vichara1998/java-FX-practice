<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="426.0" prefWidth="630.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demod14.PhoneSaveController">
   <children>
      <Label layoutX="223.0" layoutY="25.0" text="Phone Store">
         <font>
            <Font size="34.0" />
         </font>
      </Label>
      <TextField fx:id="txtModel" layoutX="31.0" layoutY="201.0" promptText="Enter Phone Model" />
      <TextField fx:id="txtBrand" layoutX="31.0" layoutY="159.0" promptText="Enter Phone Brand" />
      <TextField fx:id="txtPrice" layoutX="31.0" layoutY="247.0" promptText="Enter Price" />
      <TextField fx:id="txtQt" layoutX="31.0" layoutY="300.0" promptText="Enter Quantity" />
      <Button layoutX="80.0" layoutY="357.0" mnemonicParsing="false" onAction="#save" style="-fx-background-color: green;" text="Save Phone" textFill="WHITE" />
      <Button layoutX="381.0" layoutY="357.0" mnemonicParsing="false" onAction="#cancle" style="-fx-background-color: red;" text="Cancle" textFill="WHITE" />
   </children>
</AnchorPane>
